<div class="banner-model"></div>
<div class="container">
  <div class="row justify-content-center">
    <div class="col-12">
      <div class="btn-recettes">
        <%= link_to 'Modifier la recette', edit_recette_path(@recette), class:"btn btn-primary" %>
        <%= link_to 'Retour à la liste des recettes', recettes_path, class:"btn btn-primary" %>
      </div>
    </div>
  </div>
  <p>
    <strong>Nom :</strong>
    <%= @recette.nom %>
  </p>
  <p>
    <strong>Temps :</strong>
    <%= @recette.time %>
  </p>
  <p>
    <strong>Difficulte :</strong>
    <%= @recette.difficulte %>
  </p>
  <p>
    <strong>Note :</strong>
    <%= @recette.note %>
  </p>
  <p>
    <strong>Recette :</strong>
    <%= @recette.description %>
  </p>
  <div class="btn-recettes">
    <%= link_to "Nouvelle ingrédient", new_recette_ingredient_path(@recette), class:"btn btn-primary" %>
  </div>
  <% @recette.ingredients.each do |ingredient| %>
    <ul class="title-tab-index">
        <li><%= ingredient.nom %></li>
        <li><%= ingredient.quantite %></li>
        <li><%= ingredient.marque %></li>
        <li><%= ingredient.note %></li>
        <li><%= ingredient.prix %></li>
        <li><%= ingredient.description %></li>
        <li><%= ingredient.recette_id %></li>
        <li> <%= link_to "modifier",edit_ingredient_path %> </li>
    </ul>
  <% end %>

</div>
